APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

# Importación videosegg (MySQL). Dump por defecto: ~/Documents/videosegg/dbvideosegg_2026_04_30.sql
# 1) php artisan videosegg:load-sql
# 2) php artisan videosegg:import-posts  (copia views_count desde posts si existe columna visitas/vistas/etc.)
# 3) php artisan videosegg:sync-views    (videos ya importados: alinea views_count con la BD videoseggs otra vez)
#VIDEOSEGG_SQL_PATH=/Users/tuusuario/Documents/videosegg/dbvideosegg_2026_04_30.sql
#VIDEOSEGG_DATABASE=videoseggs
#VIDEOSEGG_DB_HOST=127.0.0.1
#VIDEOSEGG_DB_USERNAME=root
#VIDEOSEGG_DB_PASSWORD=
# Carpetas de origen (archivos descargados del servidor antiguo)
#VIDEOSEGG_VIDEOS_PATH=/Users/tuusuario/Downloads/videos
#VIDEOSEGG_IMAGENES_PATH=/Users/tuusuario/Downloads/imagenes
#VIDEOSEGG_PREVIA_PATH=/Users/tuusuario/Downloads/previa

# Carpeta por defecto para: php artisan videos:import-from-folder (sin argumento path)
#VIDEO_IMPORT_FOLDER=/Users/tuusuario/Downloads/videos

BROADCAST_DRIVER=log
CACHE_DRIVER=file
# Para colas en segundo plano (multimedia): database + php artisan queue:work
# Opcional: redis (requiere extensión y REDIS_HOST). RabbitMQ requiere paquete extra y RABBITMQ_*.
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Compresión de videos subidos al disco public (requiere ffmpeg en el servidor)
# FFMPEG_ENABLED=true
# FFMPEG_BINARY=ffmpeg
# FFMPEG_CRF=28
# FFMPEG_MAX_WIDTH=1280
# FFMPEG_PRESET=medium
# FFMPEG_TIMEOUT=900

# HLS on-demand (m3u8 + ts en primer acceso del video)
# HLS_ENABLED=true
# HLS_FFMPEG_BINARY=ffmpeg
# HLS_SEGMENT_TIME=6
# HLS_CRF=24
# HLS_PRESET=veryfast
# HLS_DELETE_SOURCE_MP4=true

# RABBITMQ_HOST=127.0.0.1
# RABBITMQ_PORT=5672
# RABBITMQ_USER=guest
# RABBITMQ_PASSWORD=guest
# RABBITMQ_VHOST=/
# Panel admin — estado de colas (plugin rabbitmq_management)
# RABBITMQ_MANAGEMENT_URL=http://127.0.0.1:15672
# RABBITMQ_MANAGEMENT_PORT=15672
# RABBITMQ_MANAGEMENT_USER=guest
# RABBITMQ_MANAGEMENT_PASSWORD=guest
# Colas a mostrar (separadas por coma); vacío = todas las del vhost
# RABBITMQ_ADMIN_QUEUE_NAMES=media,default

MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
